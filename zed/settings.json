{
  // --- Core Keymap ---
  "diff_view_style": "split",
  "base_keymap": "JetBrains",

  // --- Appearance & Theming ---
  "theme": "JetBrains Islands Dark",
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 15,

  // --- Editor Layout ---
  "project_panel": {
    "dock": "left",
  },
  "terminal": {
    "dock": "bottom",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
  },

  // --- Editor Behavior ---
  "autosave": "on_focus_change",
  "soft_wrap": "editor_width",

  // --- AI Agents ---
  "agent_servers": {
    "grok-build": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
}
