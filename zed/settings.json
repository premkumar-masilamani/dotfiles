{
  // --- Core Keymap ---
  "diff_view_style": "split",
  "base_keymap": "JetBrains",

  // --- Appearance & Theming ---
  "theme": "JetBrains Dark",
  "icon_theme": "Material Icon Theme",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 13,

  // --- Editor Layout ---
  "project_panel": {
    "dock": "left",
  },
  "terminal": {
    "dock": "bottom",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
  },

  // --- Editor Behavior ---
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "soft_wrap": "editor_width",

  // --- AI Agents ---
  "agent_servers": {
    "grok-build": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },

  // --- Language Servers ---
  "lsp": {
    "jdtls": {
      "settings": {
        "lombok_support": true,
      },
    },
  },
}
