{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry",
    },
  },
  "ssh_connections": [
    {
      "host": "github.com",
      "args": [],
      "projects": [],
    },
  ],
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "play_sound_when_agent_done": "always",
  },
  "icon_theme": "Material Icon Theme",
  "theme": "Catppuccin Frappé",
  "base_keymap": "JetBrains",
  "confirm_quit": true,
  "restore_on_startup": "last_workspace",
  "close_on_file_delete": true,
  "title_bar": {
    "show_menus": true,
  },
  "minimap": {
    "show": "auto",
  },
  "autosave": "on_focus_change",
  "soft_wrap": "editor_width",
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
}
