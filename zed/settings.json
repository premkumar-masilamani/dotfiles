{
  "features": {
    "edit_prediction_provider": "zed"
  },
  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-sonnet-latest"
    },
    "version": "2"
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "base_keymap": "JetBrains",
  "soft_wrap": "editor_width",
  "autosave": "on_focus_change",
  "languages": {
    "HTML": {
      "format_on_save": "off"
    }
  }
}
